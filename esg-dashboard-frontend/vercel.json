{
  "version": 2,
  "buildCommand": "npm run build:prod",
  "outputDirectory": "dist/esg-portfolio-dashboard",
  "installCommand": "npm ci",
  "framework": "angular",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://your-backend-url.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
