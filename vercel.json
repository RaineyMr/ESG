{
  "version": 2,
  "buildCommand": "cd esg-dashboard-frontend && npm run build",
  "outputDirectory": "esg-dashboard-frontend/dist/esg-portfolio-dashboard",
  "installCommand": "cd esg-dashboard-frontend && npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://tezicztsnkyhfikyahal.supabase.co/functions/v1/$1"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/esg-dashboard-frontend/index.html"
    }
  ]
}
